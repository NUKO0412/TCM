# Scripts locaux UNIQUEMENT (seed, assignation des rôles).
# Copie ce fichier en `supabase/.env` (ignoré par git) et remplis les valeurs.
# La clé service contourne la RLS : elle ne doit JAMAIS être exposée au front
# ni préfixée par VITE_. Elle reste sur ta machine.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Emails des 2 comptes créés dans le dashboard Supabase (pour assigner les rôles).
THEO_EMAIL=
SUPER_ADMIN_EMAIL=
