# Front-end (Vite) — valeurs PUBLIQUES, sûres dans le navigateur.
# Copie ce fichier en `app/.env.local` (ignoré par git) et remplis les valeurs
# depuis ton projet Supabase : Project Settings → API.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Serveur uniquement — ne jamais exposer dans le navigateur.
SUPABASE_SERVICE_ROLE_KEY=

# Google Search Console refresh (service account avec accès à la propriété GSC).
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://www.tcmagencement.fr/
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GSC_REFRESH_SECRET=

# Optionnel pour Vercel Cron : Vercel envoie Authorization: Bearer $CRON_SECRET.
CRON_SECRET=
